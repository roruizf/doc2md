# doc2md environment variables
# Copy to .env and fill in your values (never commit .env)

# Required for --images=vlm
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override default VLM model
# DOC2MD_VLM_MODEL=deepseek/deepseek-vl2-small

# Optional: VLM cost confirmation threshold in USD (default: 1.00)
# DOC2MD_VLM_COST_THRESHOLD=1.00
